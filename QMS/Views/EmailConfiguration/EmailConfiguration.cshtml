@using Microsoft.AspNetCore.Http
@using QMS.Core.Models


@model EmailConfigurationViewModel

@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Email / SMTP Settings";

    var userRoleId = HttpContextAccessor.HttpContext.Session.GetInt32("UserRole");

}
<meta charset="UTF-8">

<link href="~/css/fontawesome/styles.min.css" rel="stylesheet" />
<script src="~/js/jquery.min.js"></script>
<script src="~/js/jquery.datatables.js"></script>
<link href="~/css/pnotify.css" rel="stylesheet" />
<script src="~/js/pnotify.js"></script>
<script src="~/js/pnotify.confirm.js"></script>
<script src="~/lib/bootstrap/dist/js/datatables.buttons.min.js"></script>
<script src="~/lib/bootstrap/dist/js/popupAlert.js"></script>
<script src="~/lib/bootstrap/dist/js/jszip.min.js"></script>
<script src="~/lib/bootstrap/dist/js/buttons.html5.min.js"></script>
<script src="~/js/common.js"></script>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>


    .content {
        padding: 20px;
    }

    .card-header {
        background: white;
        padding: 12px 20px;
        font-size: 18px;
        font-weight: 600;
        border-radius: 8px 8px 0 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid #ddd;
    }

    .nav-tabs {
        display: flex;
        overflow-x: auto;
        white-space: nowrap;
        border-bottom: 1px solid #ddd;
        background: #fff;
    }

        .nav-tabs button {
            border: none;
            background: none;
            padding: 12px 16px;
            font-weight: 500;
            cursor: pointer;
            color: #333;
        }

            .nav-tabs button.active {
                border-bottom: 3px solid #007bff;
                font-weight: bold;
                color: #007bff;
            }

    .tab-content {
        background: #fff;
        border: 1px solid #ddd;
        border-top: none;
        padding: 25px;
        border-radius: 0 0 8px 8px;
        max-width: 850px;
        margin: auto;
    }

    .form-group {
        margin-bottom: 20px;
    }

    label {
        display: block;
        font-weight: 600;
        margin-bottom: 6px;
    }

    input, textarea {
        width: 100%;
        padding: 10px;
        font-size: 14px;
        border: 1px solid #ccc;
        border-radius: 4px;
    }

    textarea {
        resize: vertical;
    }

    .row {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .col-6 {
        flex: 0 0 48%;
    }

    .col-12 {
        flex: 0 0 100%;
    }

    .switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 25px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 25px;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 19px;
            width: 19px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    .switch input:checked + .slider {
        background-color: #28a745;
    }

        .switch input:checked + .slider:before {
            transform: translateX(24px);
        }

    .form-footer {
        text-align: right;
        padding-top: 20px;
    }

    .btn1 {
        padding: 10px 20px;
        background: #28a745;
        color: #fff;
        border: none;
        font-size: 14px;
        border-radius: 4px;
        cursor: pointer;
    }

    .btn i {
        margin-right: 6px;
    }

    .card {
        border-radius: 0.5rem;
        box-shadow: 0 4px 12px rgba(17, 122, 139, 0.4);
    }

    .nav-tabs {
        border-radius: 0.5rem;
        box-shadow: 0 4px 12px rgba(17, 122, 139, 0.4);
    }

    .tab-content {
        border-radius: 0.5rem;
        box-shadow: 0 4px 12px rgba(17, 122, 139, 0.4);
    }
</style>



<div class="content">
    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap" style="padding-top:8px;padding-bottom:8px;">
            <div style="font-size:18px; font-weight: 600;">
                <i class="fas fa-envelope text-primary me-2"></i> Email / SMTP Settings
            </div>
            <button id="backButton" class="btn btn-outline-danger">
                <i class="fas fa-arrow-left"></i> Back
            </button>
        </div>
    </div>


    <!-- Tab Content -->
    <div class="tab-content">
        <form id="smtpSetting-form" method="post" asp-action="InsertUpdateEmailConfiguration" asp-controller="EmailConfiguration">
            <div class="row col-12">
                @Html.HiddenFor(m => m.Id)
                <div class="form-group col-12">
                    <label>From Email</label>
                    @Html.TextBoxFor(m => m.From, new { @type = "email", placeholder = "you@example.com", autocomplete = "email" })

                </div>
                <div class="form-group col-12">
                    <label>User Name</label>
                    @Html.TextBoxFor(m => m.SMTPUserName, new { placeholder = "SMTP Username", autocomplete = "username" })
                </div>
                <div class="form-group col-12">
                    <label>Password</label>
                    @Html.PasswordFor(m => m.SMTPPassword, new { placeholder = "********", autocomplete = "new-password" })

                </div>
            </div>
            <div class="row col-12">
                <div class="form-group col-5">
                    <label>Host</label>
                    @Html.TextBoxFor(m => m.SmtpServer, new { placeholder = "smtp.yourdomain.com" })

                </div>
                <div class="form-group col-2">
                    <label>Port</label>
                    @Html.TextBoxFor(m => m.Port, new { @type = "number", placeholder = "587", min = "1" })

                </div>
                <div class="form-group col-2">
                    <label class="pb-2">SSL Required</label>
                    <label class="switch">
                        <input id="chkSSL" type="checkbox" @(Model?.SslRequired == true ? "checked" : "") />
                        <span class="slider"></span>
                    </label>
                </div>
            </div>
        </form>
        <div class="form-footer">

            <button type="button" class="btn1" onclick="InsertUpdateSMTPSetting()"><i class="fas fa-save"></i> Save Configuration</button>
        </div>
    </div>
</div>

<script asp-append-version="true">
    function InsertUpdateSMTPSetting() {
        Blockloadershow();
        const requiredFields = [
            { id: 'From', name: 'From Email' },
            { id: 'SMTPUserName', name: 'User Name' },
            { id: 'SMTPPassword', name: 'Password' },
            { id: 'SmtpServer', name: 'Host' },
            { id: 'Port', name: 'Port' }
        ];

        let isValid = true;
        let missingFields = [];

        requiredFields.forEach(field => {
            const element = $('#' + field.id);
            if (!element.val() || element.val().length == 0) {
                isValid = false;
                missingFields.push(field.name);
                element.addClass('missing-field');
            }
        });

        if (!isValid) {
            const missingFieldsList = missingFields.map(field => `<li>${field}</li>`).join('');
            const alertMessage = `
                    <p>Please fill out the following required field(s):</p>
                    <ul>${missingFieldsList}</ul>
                `;
            showDangerAlert(alertMessage);
            Blockloaderhide();
            return false;
        }

        const form = $('#smtpSetting-form')[0];
        const formData = new FormData(form);

        formData.append('Id', $("#Id").val());
        var isChecked = $('#chkSSL').is(':checked');
        formData.append('SslRequired', isChecked);

        $.ajax({
            url: $('#smtpSetting-form').attr('action'),
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function (response) {
                Blockloaderhide();
                if (!response.success) {
                    var errorMessg = "";
                    for (var error of response.errors) {
                        errorMessg += error + "\n";
                    }
                    if (errorMessg != "") {
                        showDangerAlert(errorMessg);
                    }
                    else {
                        showDangerAlert(response.message);
                    }
                    return false;
                }
                else {
                    if ($("#Id").val() > 0) {
                        showSuccessAlert("Email / SMTP Setting Updated Successfully.");
                    }
                    else {
                        showSuccessAlert("Email / SMTP Setting Saved Successfully.");
                    }
                    setTimeout(function () {
                        window.location.reload();
                    }, 2500);
                }
            },
            error: function (xhr, status, error) {
                Blockloaderhide();
                showDangerAlert('Error saving data: ' + error);
            }
        });
    }
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@section HideSidebar { }

